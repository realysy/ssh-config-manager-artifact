---
// 接收当前页面的语言属性
const { lang = 'zh' } = Astro.props;
// Giscus 语言映射, 'zh-CN' 对应中文, 'en' 对应英文
const giscusLang = lang === 'zh' ? 'zh-CN' : 'en';
---

<!-- 评论区容器 -->
<div class="giscus-wrapper" style="margin-top: 40px; padding-top: 20px; border-top: 1px solid #d0d7de;">
  <h2 style="margin-bottom: 16px; font-size: 1.2em; color: #667eea;">💬 {lang === 'zh' ? '评论' : 'Comments'}</h2>
  <script src="https://giscus.app/client.js"
          data-repo="realysy/ssh-config-manager-artifact"
          data-repo-id="R_kgDOSXpgUg"
          data-category="Announcements"
          data-category-id="DIC_kwDOSXpgUs4C_yNi"
          data-mapping="pathname"
          data-strict="1"
          data-reactions-enabled="1"
          data-emit-metadata="0"
          data-input-position="bottom"
          data-theme="light"
          data-lang={giscusLang}
          crossorigin="anonymous"
          async>
  </script>
</div>

<style>
  /* 确保 Giscus iframe 自适应宽度 */
  .giscus-wrapper :global(.giscus-frame) {
    width: 100%;
    border: none;
  }
</style>