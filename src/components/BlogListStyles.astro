<!-- src/components/BlogListStyles.astro -->
<style is:global>
  .blog-main-title {
    font-size: 2em;
    margin-bottom: 32px;
    /* 🛠️ 修复: 替换原有的 #667eea, 统一为科技蓝 */
    border-bottom: 2px solid #0969da; 
    padding-bottom: 12px;
    /* 🛠️ 修复: 替换原有的 #24292f, 与全局 H1 标题颜色统一 */
    color: #1f2328; 
  }
  
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 24px;
    align-items: stretch; /* 强制同一行的卡片高度完全一致 */
  }
  
  .blog-card-new {
    background: #fff;
    border: 1px solid #e0e0e0;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    overflow: hidden; 
    padding: 0;
    height: 100%; /* 确保卡片高度占满网格单元格 */
  }
  
  .blog-card-new:hover {
    text-decoration: none;
    transform: translateY(-4px);
    /* 🛠️ 修复: 替换原有的蓝紫阴影为科技蓝阴影 */
    box-shadow: 0 12px 24px rgba(9, 105, 218, 0.15); 
    border-color: #0969da;
  }

  .card-cover {
    width: 100%;
    overflow: hidden;
    background: #f6f8fa;
    flex-shrink: 1; /* 允许封面在必要时收缩，为正文腾出空间 */
    min-height: 0;  /* 防止 flex 子项溢出 */
  }
  
  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover; 
    transition: transform 0.3s ease;
  }

  .blog-card-new:hover .card-cover img {
    transform: scale(1.05); 
  }

  .card-cover-fallback {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
    color: #fff;
    text-align: center;
    position: relative;
    overflow: hidden;
    flex-shrink: 2; /* 封面回退区域更激进地收缩，优先保证标题空间 */
    min-height: 60px; /* 设置一个合理的最小高度，防止完全压扁 */
  }

  .fallback-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px; 
    justify-content: center;
    align-items: center;
    max-width: 100%;
  }

  /* ✨ 补全缺失的单个标签毛玻璃样式 */
  .fallback-tag {
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    text-shadow: 0 1px 2px rgba(0,0,0,0.1);
    white-space: nowrap;
    transition: transform 0.3s ease, background 0.3s ease;
  }
  
  .blog-card-new:hover .fallback-tag {
    background: rgba(255, 255, 255, 0.35);
    transform: translateY(-2px);
  }

  /* 🎨 6 种现代感极客渐变色 */
  .gradient-0 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
  .gradient-1 { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); }
  .gradient-2 { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); }
  .gradient-3 { background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); }
  .gradient-4 { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); }
  .gradient-5 { background: linear-gradient(135deg, #30cfd0 0%, #330867 100%); }
  
  .card-body {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex: 1; /* 填充剩余空间，确保同行的卡片高度一致 */
  }
  
  .card-title {
    font-size: 1.25em;
    margin: 0 0 12px 0;
    color: #24292f;
    line-height: 1.4;
    font-weight: 600;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    min-height: calc(1.25em * 1.4 * 1);
    flex-shrink: 0; /* 标题高度固定，不做伸缩 */
  }
  
  .card-desc {
    font-size: 14px;
    color: #656d76;
    margin-bottom: 16px;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2; /* 限制最多显示 2 行描述 */
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    flex-shrink: 0;
  }
  
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: auto; /* 将日期和 read more 推至卡片底部 */
    flex-shrink: 0;
  }
  
  .card-date {
    font-size: 13px;
    color: #0969da; 
    font-weight: 600;
    margin-bottom: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  
  .card-read-more {
    color: #0969da; 
    font-weight: 500;
    font-size: 14px;
  }

  /* 暗色模式适配 */
  [data-theme="dark"] .blog-card-new {
    background: #1e1e1e;
    border-color: #444;
  }
  [data-theme="dark"] .card-title {
    color: #e2e8f0;
  }
  [data-theme="dark"] .card-desc {
    color: #a0aec0;
  }
  [data-theme="dark"] .card-date {
    color: #8b9cf7;
  }
  [data-theme="dark"] .card-read-more {
    color: #8b9cf7;
  }
</style>