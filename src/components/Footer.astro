---
// src/components/Footer.astro
import { SITE_CONFIG } from '@/utils/config';
import { getLangFromPath } from '@/utils/i18n';

// 获取当前路径判断语言
const currentPath = Astro.url.pathname;
const isZh = getLangFromPath(currentPath, import.meta.env.BASE_URL) === 'zh';
const langPrefix = isZh ? 'zh/' : '';

let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith('/')) baseUrl += '/';
---

<footer class="footer">
  <div class="footer-links">
    <a href={`${baseUrl}${langPrefix}templates/privacy/`}>
      {isZh ? "隐私政策" : "Privacy Policy"}
    </a>
    <a href={`${baseUrl}${langPrefix}templates/terms/`}>
      {isZh ? "使用条款" : "Terms of Use"}
    </a>
  </div>
  <p>
    {isZh 
      ? `${SITE_CONFIG.appName} (${SITE_CONFIG.appShortName}) - 高效管理您的 SSH 连接` 
      : `${SITE_CONFIG.appName} (${SITE_CONFIG.appShortName}) - Manage your SSH connections efficiently`}
  </p>
  <p style="margin-top: 8px; font-size: 13px;">© All rights reserved. <a
      href={SITE_CONFIG.githubRepo}
      target="_blank">{SITE_CONFIG.githubRepo}</a></p>
</footer>