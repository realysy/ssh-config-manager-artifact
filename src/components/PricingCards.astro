---
// src/components/PricingCards.astro
import { getLangFromPath } from '@/utils/i18n';

// 🌟 1. 直接从 src/assets 导入二维码图片
// Astro 会自动处理它们的路径、base 前缀以及添加 hash
import qrItch from '@/assets/qrcode_itch_io.png';
import qrTaobao from '@/assets/qrcode_taobao.png';

// 🛡️ 防呆处理: 确保 baseUrl 永远以斜杠结尾 (仅用于处理其它可能的静态文本链接)
let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith('/')) baseUrl += '/';

const currentPath = Astro.url.pathname;
const isZh = getLangFromPath(currentPath, baseUrl) === 'zh';
---

<div class="channels-grid">
  <!-- itch.io 渠道卡片 -->
  <div class="channel-card">
    <div class="channel-header">
      <span class="channel-icon">🌍</span>
      <span class="channel-name">{isZh ? '海外用户 (itch.io)' : 'Global Users (itch.io)'}</span>
    </div>
    <div class="channel-content">
      <div class="channel-left">
        <!-- 🌟 2. 使用 .src 属性渲染图片, Astro 会自动注入正确的完整 URL -->
        <img src={qrItch.src} alt={isZh ? 'itch.io 购买二维码' : 'itch.io QR Code'} class="qr-code" loading="lazy">
        <div class="channel-price" id="price-itch">$28.9</div>
      </div>

      <div class="channel-info">
        <h3 class="channel-title">SSH Config Manager</h3>
        <p class="channel-author">by realysy</p>
        <div class="payment-methods">
          <span class="method-label">{isZh ? '支持:' : 'Supports:'}</span>
          <span class="method-tag">PayPal</span>
          <span class="method-tag">{isZh ? '信用卡' : 'Credit Card'}</span>
          <span class="method-tag">{isZh ? '借记卡' : 'Debit Card'}</span>
        </div>
        <div class="payment-highlight-note">✨ {isZh ? '无需注册账号, 凭邮箱即可购买.' : 'No account registration required, purchase with email.'}</div>
        <div class="payment-highlight-note">✨ {isZh ? '支付成功后, itch.io 会自动发放 download key 作为激活码.' : 'After payment, itch.io automatically issues a download key as the activation code.'}</div>
        <a href="https://realysy.itch.io/ssh-config-manager" target="_blank" rel="noopener noreferrer" class="buy-btn itch-buy-btn">
          🛒 {isZh ? '前往 itch.io 购买' : 'Buy on itch.io'}
        </a>
      </div>
    </div>

    <!-- 🌟 添加错误提示占位符, 默认隐藏 -->
    <p class="channel-note" id="note-itch" style="display: none;"></p>
  </div>

  <!-- 淘宝渠道卡片 -->
  <div class="channel-card">
    <div class="channel-header">
      <span class="channel-icon">🇨🇳</span>
      <span class="channel-name">{isZh ? '中国大陆用户 (淘宝)' : 'Mainland China Users (Taobao)'}</span>
    </div>
    <div class="channel-content">
      <div class="channel-left">
        <img src={qrTaobao.src} alt={isZh ? '淘宝购买二维码' : 'Taobao QR Code'} class="qr-code" loading="lazy">
        <div class="channel-price" id="price-tb">¥88</div>
      </div>

      <div class="channel-info">
        <h3 class="channel-title">SSH Config Manager</h3>
        <p class="channel-author">{isZh ? '购买力平价 (PPP) 折扣' : 'Purchasing Power Parity (PPP) Discount'}</p>
        <div class="payment-methods">
          <span class="method-label">{isZh ? '支持:' : 'Supports:'}</span>
          <span class="method-tag">{isZh ? '支付宝' : 'Alipay'}</span>
          <span class="method-tag">{isZh ? '微信支付' : 'WeChat Pay'}</span>
          <span class="method-tag">{isZh ? '花呗' : 'Huabei'}</span>
          <span class="method-tag">{isZh ? '银行卡' : 'Bank Card'}</span>
        </div>
        <div class="payment-highlight-note">📱 {isZh ? '需使用淘宝/支付宝账号登录购买.' : 'Requires Taobao/Alipay account to purchase.'}</div>
        <div class="payment-highlight-note">📱 {isZh ? '支付成功后, 请联系卖家客服获取激活码.' : 'After payment, please contact the seller\'s customer service to get the activation code.'}</div>
        <a href="https://item.taobao.com/item.htm?ft=t&id=1055953631461" target="_blank" rel="noopener noreferrer" class="buy-btn taobao-buy-btn">
          🛒 {isZh ? '前往淘宝购买' : 'Buy on Taobao'}
        </a>
      </div>
    </div>

    <!-- 🌟 添加错误提示占位符, 默认隐藏 -->
    <p class="channel-note" id="note-tb" style="display: none;"></p>
  </div>
</div>

<style>
  /* ========== 购买渠道卡片样式 (复用自激活页面) ========== */
  .channels-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 20px;
    margin-bottom: 20px;
  }

  .channel-card {
    background: #fafafa;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 20px;
    transition: all 0.3s;
  }

  .channel-card:hover {
    border-color: #667eea;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.15);
    transform: translateY(-2px);
  }

  .channel-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid #edf2f7;
  }

  .channel-icon { font-size: 24px; }
  .channel-name { font-size: 16px; font-weight: 600; color: #333; }

  .channel-content {
    display: flex;
    flex-direction: row; 
    align-items: center;
    gap: 20px;
    width: 100%;
  }

  @media (max-width: 480px) {
    .channel-content {
      flex-direction: column;
      text-align: center;
    }
    .channel-info { align-items: center; }
  }

  .channel-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .channel-price {
    font-size: 22px;
    font-weight: 700;
    color: #e53e3e;
    margin: 0;
  }

  /* 恢复使用原有的二维码图片样式 */
  .qr-code {
    width: 120px;
    height: 120px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .channel-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .channel-title { font-size: 16px; font-weight: 600; color: #333; margin: 0; }
  .channel-author { font-size: 13px; color: #718096; margin: 0; }

  .payment-methods {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-top: 4px;
    margin-bottom: 8px;
  }

  .method-label { font-size: 12px; color: #718096; margin-right: 2px; }
  
  .method-tag {
    display: inline-block;
    font-size: 11px;
    background: #e2e8f0;
    color: #4a5568;
    padding: 2px 8px;
    border-radius: 12px;
    font-weight: 500;
  }

  .payment-highlight-note {
    display: block;
    width: fit-content;
    font-size: 12px;
    color: #718096;
    border-radius: 4px;
  }

  .buy-btn {
    display: inline-block;
    padding: 8px 24px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 20px;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s;
    margin-top: 10px;
    width: fit-content;
    border: none;
    cursor: pointer;
  }

  .itch-buy-btn { background: #fa5c5c; color: white; }
  .itch-buy-btn:hover { background: #e04b4b; color: white; transform: translateY(-1px); text-decoration: none; }

  .taobao-buy-btn { background: linear-gradient(90deg, #ff4400, #ff6a00); color: white; }
  .taobao-buy-btn:hover { background: linear-gradient(90deg, #e63e00, #e65c00); color: white; transform: translateY(-1px); text-decoration: none; }

   /* 卡片下方的错误提示语样式 */
  .channel-note {
    font-size: 12px;
    color: #e53e3e; /* 警告红色 */
    text-align: center;
    margin-top: 16px;
    padding-top: 12px;
    border-top: 1px dashed #e2e8f0; /* 虚线分割 */
    line-height: 1.5;
    margin-bottom: 0;
  }

  /* 暗黑模式适配 */
  [data-theme="dark"] .channel-card { background: #2d2d2d; border-color: #444; }
  [data-theme="dark"] .channel-header { border-bottom-color: #444; }
  [data-theme="dark"] .channel-name,
  [data-theme="dark"] .channel-title { color: #e2e8f0; }
  [data-theme="dark"] .channel-author,
  [data-theme="dark"] .method-label,
  [data-theme="dark"] .payment-highlight-note { color: #a0aec0; }
  [data-theme="dark"] .method-tag { background: #444; color: #e2e8f0; }
  [data-theme="dark"] .qr-code { border-color: #444; }
  [data-theme="dark"] .channel-note { 
    border-top-color: #444; 
    color: #fc8181; /* 暗色模式下的柔和红色 */
  }
</style>


<script>
  // 🌟 1. 定义 JSON 数据的 TypeScript 接口
  interface PriceInfo {
    price: number | string;
    currency: string;
  }

  interface PriceData {
    itch?: PriceInfo;
    tb?: PriceInfo;
  }

  // 🌍 根据当前 HTML lang 属性判断语言, 决定错误提示文本
  const isZh = document.documentElement.lang === 'zh';
  const errorMsg = isZh 
    ? '⚠️ 获取最新售价失败, 请扫描二维码或点击购买按钮前往购买页面查看最新价格.' 
    : '⚠️ Failed to fetch latest prices. Please scan the QR code or click the buy button to check the latest price on the store page.';

  const noteItch = document.getElementById('note-itch');
  const noteTb = document.getElementById('note-tb');

  // 🌟 2. 为 data 参数添加类型注解, 修复隐式 any 报错
  function updatePriceFromData(data: PriceData): boolean {
    let success = false;
    
    // 🌟 3. 提前获取 DOM 元素, 并使用 if 判空修复 'Object is possibly null' 报错
    const priceItchEl = document.getElementById('price-itch');
    const priceTbEl = document.getElementById('price-tb');

    // 更新 itch.io 价格
    if (data.itch && typeof data.itch.price !== 'undefined') {
      const symbol = data.itch.currency === 'USD' ? '$' : (data.itch.currency + ' ');
      if (priceItchEl) priceItchEl.textContent = symbol + data.itch.price;
      success = true;
    } else if (noteItch) {
      noteItch.textContent = errorMsg;
      noteItch.style.display = 'block';
    }
    
    // 更新淘宝价格
    if (data.tb && typeof data.tb.price !== 'undefined') {
      const symbol = data.tb.currency === 'CNY' ? '¥' : (data.tb.currency + ' ');
      if (priceTbEl) priceTbEl.textContent = symbol + data.tb.price;
      success = true;
    } else if (noteTb) {
      noteTb.textContent = errorMsg;
      noteTb.style.display = 'block';
    }
    
    return success;
  }

  // 🌟 4. 为 url 添加 string 注解, 为返回值添加 Promise<PriceData> 注解
  async function tryFetchFromUrl(url: string): Promise<PriceData> {
    const resp = await fetch(`${url}?t=${Date.now()}`, { cache: 'no-store' });
    if (!resp.ok) throw new Error('Network response was not ok');
    // 使用 as PriceData 进行类型断言
    return await resp.json() as PriceData; 
  }

  async function fetchPrices(): Promise<void> {
    // 🌟 动态构建主 URL, 完美兼容 Astro 的 site 和 base 配置 (如 GitHub Pages 子路径)
    const site = import.meta.env.SITE || window.location.origin;
    const base = import.meta.env.BASE_URL || '/';
    
    // 🛠️ 核心修复: 确保 base 以斜杠结尾, 防止与文件名直接粘连 (如 .../artifactprices.json)
    const normalizedBase = base.endsWith('/') ? base : `${base}/`;
    
    // 拼接并清理可能出现的双斜杠 (排除 http:// 或 https:// 中的斜杠)
    const primaryUrl = `${site}${normalizedBase}prices.json`.replace(/([^:]\/)\/+/g, "$1"); 
    
    // 🛡️ 兜底: GitHub Raw 链接 (确保即使官网 CDN 出问题也能获取到价格)
    const fallbackUrl = 'https://raw.githubusercontent.com/realysy/ssh-config-manager-artifact/main/public/prices.json';

    try {
      // 1. 先尝试主 URL
      const data = await tryFetchFromUrl(primaryUrl);
      updatePriceFromData(data);
    } catch (e1) {
      console.warn('Primary price URL failed, trying fallback:', e1);
      try {
        // 2. 主 URL 失败, 尝试 GitHub 备用 URL
        const data = await tryFetchFromUrl(fallbackUrl);
        updatePriceFromData(data);
      } catch (e2) {
        console.warn('Fallback price URL also failed, showing error tips:', e2);
        // 3. 两个 URL 都失败, 显示错误提示
        if (noteItch) { noteItch.textContent = errorMsg; noteItch.style.display = 'block'; }
        if (noteTb) { noteTb.textContent = errorMsg; noteTb.style.display = 'block'; }
      }
    }
  }

  // 页面加载完成后执行
  fetchPrices();
</script>