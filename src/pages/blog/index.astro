---
// src/pages/blog/index.astro
// 英文博客列表页面: 显示博客卡片

import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import BlogListStyles from "@/components/BlogListStyles.astro";
import BlogCard from "@/components/BlogCard.astro";
import { SITE_CONFIG } from '@/utils/config';
import { getGroupedPosts, getDisplayPost } from "@/utils/getPostsByLang";
import { getAutoCover } from "@/utils/getAutoCover";

let baseUrl = import.meta.env.BASE_URL;
if (!baseUrl.endsWith("/")) baseUrl += "/";

const groupedPosts: Awaited<ReturnType<typeof getGroupedPosts>> =
  await getGroupedPosts();
groupedPosts.sort((a, b) => {
  const postA = getDisplayPost(a, "en");
  const postB = getDisplayPost(b, "en");
  return (
    (postB?.data.pubDate?.getTime() || 0) -
    (postA?.data.pubDate?.getTime() || 0)
  );
});

function getColorIndex(str: string) {
  let hash = 0;
  for (let i = 0; i < str.length; i++) {
    hash = str.charCodeAt(i) + ((hash << 5) - hash);
  }
  return Math.abs(hash) % 6;
}
---

<Layout title=`Blog - ${SITE_CONFIG.appName}` lang="en">
  <BlogListStyles />

  <div class="page-wrapper">
    <Header />
    <div class="container">
      <h1 class="blog-main-title">📝 Development Blog</h1>

      <div class="blog-grid">
        {
          groupedPosts.length > 0 ? (
            groupedPosts.map((group) => {
              const post = getDisplayPost(group, "en");
              const coverUrl = getAutoCover(post.body);
              const colorIdx = getColorIndex(group.coreSlug);

              return (
                // ✨ 直接传入 Props，HTML 结构全部交给组件处理
                <BlogCard
                  post={post}
                  coverUrl={coverUrl}
                  colorIdx={colorIdx}
                  href={`${baseUrl}blog/${group.coreSlug}/`}
                  lang="en"
                />
              );
            })
          ) : (
            <p>No posts yet.</p>
          )
        }
      </div>
    </div>
    <Footer />
  </div>
</Layout>
